# ============================================================
# Techia — Environment Variables Template
# ============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Railway production: set these in Railway Dashboard
# ============================================================

# ── Server ──────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────
# Railway: use PostgreSQL plugin — it auto-injects DATABASE_URL
# Local: postgresql://user:password@localhost:5432/db?schema=public
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/system?schema=public"

# ── JWT ─────────────────────────────────────────────────
# Min 32 characters — generate with: openssl rand -hex 64
JWT_SECRET="change-this-to-a-secure-random-string-at-least-32-chars"
JWT_ACCESS_TOKEN_TTL=15m

# ── Prisma ──────────────────────────────────────────────
# Set to "true" to log all Prisma queries (development only)
PRISMA_LOG_QUERIES=false

# ── CORS ────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000"

# ── Web (used by Next.js) ──────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"


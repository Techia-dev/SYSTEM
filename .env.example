JWT_ACCESS_TOKEN_TTL=15m
PORT=4000
HOST=0.0.0.0
CORS_ORIGINS=https://your-production-domain.com
LOG_LEVEL=info

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

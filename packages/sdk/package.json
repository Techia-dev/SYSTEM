{
  "name": "@techia/sdk",
  "version": "1.0.0",
  "description": "Type-safe SDK for Techia ATS API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@techia/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ats",
    "sdk",
    "api-client",
    "techia"
  ],
  "author": "Techia Team",
  "license": "MIT"
}

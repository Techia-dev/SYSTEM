# ============================================================
# Techia API — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For Railway production: set these in Railway Dashboard
# ============================================================

# ── Server ──────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────
# Railway: use PostgreSQL plugin connection string
DATABASE_URL="postgresql://user:password@host:5432/db?schema=public&connection_limit=5"

# ── JWT ─────────────────────────────────────────────────
# Min 32 characters
JWT_SECRET="change-this-to-a-secure-random-string-at-least-32-chars"
JWT_ACCESS_TOKEN_TTL=5m

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins (with protocol)
CORS_ORIGINS="http://localhost:3000"

# ============================================================
# Techia API — Environment Variables
# ============================================================
# For local dev: copy to .env and edit
# For production: set these in Railway Dashboard → Variables
# ============================================================

# ── Server ──────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────
# Railway PostgreSQL plugin sets this automatically.
# For local dev, change to your local connection string.
DATABASE_URL="postgresql://postgres:aGkvJQbAHbKkNLCzwTCZeimWbRwGVOsm@postgres.railway.internal:5432/railway?schema=public"

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET="0aa368a1c0e2d52e1d24647b185aaeb12b3d359e708125561f480e431b27b7d31f6ec53f1b0ee9b76cf29098c23a7c8fc56168448f8a6525efeb454914bfd42e"
JWT_ACCESS_TOKEN_TTL=5m

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins (with protocol)
CORS_ORIGINS="https://system-web-zeta.vercel.app"

# ── Railway PostgreSQL plugin (auto-set, read-only) ─────
# PGPORT=5432
# PGUSER=${{POSTGRES_USER}}
# PGHOST=${{RAILWAY_PRIVATE_DOMAIN}}

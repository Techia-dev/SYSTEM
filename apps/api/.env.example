# ============================================================
# Techia API — Environment Variables
# ============================================================
# For local dev: copy to .env and edit
# For production: set these in Railway Dashboard — Variables
# ============================================================

# ── Server ──────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────
# Railway PostgreSQL plugin sets this automatically.
# For local dev, change to your local connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/techia?schema=public"

# ── JWT ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET="replace-with-a-random-string-at-least-32-characters-long"
JWT_ACCESS_TOKEN_TTL=15m

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins (with protocol)
CORS_ORIGINS="http://localhost:3000"

{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "build/**"
      ]
    },

    "dev": {
      "cache": false,
      "persistent": true
    },

    "mobile#dev": {
      "cache": false,
      "persistent": true
    },

    "start": {
      "dependsOn": ["build"],
      "cache": false
    },

    "lint": {
      "outputs": []
    },

    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  },

  "ui": "stream"
}